#!/usr/bin/env python3
"""
stt — Local speech-to-text CLI for macOS using whisper.cpp

Subcommands:
    stt record [-d SEC] [-D DEVICE] [--json] [--output FILE]
        Record from mic and transcribe. Ctrl+C to stop if no --duration.

    stt file <audio_file> [--json]
        Transcribe an existing audio file (wav, mp3, flac, ogg).

    stt stream [-i INTERVAL] [-D DEVICE] [--json] [-v]
        Real-time streaming transcription via whisper-server.

    stt list-devices
        List available audio input devices.

Requirements:
    - whisper.cpp built at ~/projects/stt/whisper.cpp/build/bin/whisper-cli
    - ffmpeg for audio capture
    - Model downloaded to ~/projects/stt/whisper.cpp/models/

For agent use: pipe-friendly JSON output with --json flag (stream uses JSON lines).
"""

import argparse
import json
import os
import re
import select
import shutil
import signal
import socket
import subprocess
import sys
import tempfile
import textwrap
import time
import urllib.request
from pathlib import Path
from typing import Union

# ── Paths ───────────────────────────────────────────────────────────
PROJ = Path(__file__).resolve().parent
WHISPER_CLI = PROJ / "whisper.cpp" / "build" / "bin" / "whisper-cli"
MODELS_DIR  = PROJ / "whisper.cpp" / "models"
DEFAULT_MODEL = "ggml-small.bin"

# ── Helpers ─────────────────────────────────────────────────────────

def die(msg: str, code: int = 1):
    print(f"stt: {msg}", file=sys.stderr)
    sys.exit(code)


def resolve_model(name: str) -> Path:
    """Resolve a model name to full path."""
    if "/" in name or os.path.isabs(name):
        p = Path(name)
        if p.exists():
            return p
    p = MODELS_DIR / name
    if p.exists():
        return p
    die(f"Model not found: {name} (looked in {MODELS_DIR})")


def check_deps():
    """Ensure whisper-cli and ffmpeg are available."""
    if not WHISPER_CLI.exists():
        die(f"whisper-cli not found at {WHISPER_CLI}. Run build step first.")
    if not shutil.which("ffmpeg"):
        die("ffmpeg not found in PATH. Install with: brew install ffmpeg")


def whisper_transcribe(
    audio: Path,
    model: str,
    language: str = "auto",
    json_out: bool = False,
    progress: bool = False,
    timestamps: bool = False,
) -> str:
    """Run whisper-cli and return transcription text."""
    model_path = resolve_model(model)

    cmd = [
        str(WHISPER_CLI),
        "-m", str(model_path),
        "-f", str(audio),
        "-l", language,
        "-oj" if json_out else "-otxt",
    ]

    if not timestamps and not json_out:
        cmd.append("--no-timestamps")
    if progress:
        cmd.append("-pp")
    if json_out:
        cmd.append("-of")
        cmd.append(str(audio) + ".whisper")

    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=600)
        if result.returncode != 0:
            die(f"whisper-cli failed:\n{result.stderr}")

        if json_out:
            # whisper-cli writes JSON to file, read it back then clean up
            json_path = str(audio) + ".whisper.json"
            if os.path.exists(json_path):
                with open(json_path) as f:
                    data = f.read()
                os.unlink(json_path)
                return data
            return result.stdout
        else:
            text = result.stdout.strip()
            if text in ("[BLANK_AUDIO]", "[ Silence ]"):
                return ""
            return text
    except subprocess.TimeoutExpired:
        die("Transcription timed out (>10 min). Try a shorter audio or faster model.")


# ── Server helpers (for stream mode) ────────────────────────────────

WHISPER_SERVER = PROJ / "whisper.cpp" / "build" / "bin" / "whisper-server"

def _find_free_port() -> int:
    """Return an available TCP port."""
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        s.bind(("127.0.0.1", 0))
        return s.getsockname()[1]


def _start_whisper_server(model_path: Path, language: str, port: int) -> subprocess.Popen:
    """Start whisper-server and wait until it's ready."""
    proc = subprocess.Popen(
        [
            str(WHISPER_SERVER),
            "-m", str(model_path),
            "-l", language,
            "--host", "127.0.0.1",
            "--port", str(port),
            "--no-timestamps",
            "-t", "6",           # threads for M5 Max
            "-nth", "0.5",       # balance: 0.6 too strict, 0.4 hallucinates
        ],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )

    # Wait for server to be ready (poll GET /)
    deadline = time.time() + 15
    while time.time() < deadline:
        try:
            urllib.request.urlopen(
                f"http://127.0.0.1:{port}/", timeout=1
            )
            return proc
        except Exception:
            time.sleep(0.3)

    proc.kill()
    die("whisper-server failed to start within 15s")


def _transcribe_via_server(wav_data: bytes, filename: str, port: int, language: str) -> str:
    """POST WAV bytes to whisper-server, return transcription text."""
    import io

    boundary = "----WhisperBoundary"
    body = (
        f"--{boundary}\r\n"
        f'Content-Disposition: form-data; name="file"; filename="{filename}"\r\n'
        f"Content-Type: audio/wav\r\n\r\n"
    ).encode() + wav_data + f"\r\n--{boundary}--\r\n".encode()

    req = urllib.request.Request(
        f"http://127.0.0.1:{port}/inference",
        data=body,
        headers={
            "Content-Type": f"multipart/form-data; boundary={boundary}",
        },
    )

    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            result = json.loads(resp.read())
            text = result.get("text", "").strip()
            if text in ("", "[BLANK_AUDIO]", "[ Silence ]"):
                return ""
            return text
    except Exception:
        return ""


def list_devices():
    """Print available AVFoundation audio input devices."""
    result = subprocess.run(
        ["ffmpeg", "-f", "avfoundation", "-list_devices", "true", "-i", ""],
        capture_output=True, text=True,
    )
    # ffmpeg prints device list to stderr; extract just audio devices
    in_audio = False
    for line in result.stderr.split("\n"):
        if "AVFoundation audio devices:" in line:
            in_audio = True
            continue
        if in_audio:
            if "Error" in line or not line.strip():
                break
            # Parse: [AVFoundation indev ...] [0] Device Name
            if "] [" in line:
                label = line.split("] ", 2)[-1] if "] " in line else line
                print(label)


# ── Commands ────────────────────────────────────────────────────────

def cmd_record(args):
    """Record audio from mic, then transcribe."""
    tmp = tempfile.NamedTemporaryFile(suffix=".wav", delete=False)
    tmp_path = tmp.name
    tmp.close()

    duration = args.duration
    device = getattr(args, "device", ":0")

    # Build ffmpeg command
    ffmpeg_cmd = [
        "ffmpeg",
        "-f", "avfoundation",
        "-i", device,          # user-selectable microphone
        "-ar", "16000",        # whisper native sample rate
        "-ac", "1",            # mono
        "-sample_fmt", "s16",
        "-y",
    ]
    if duration:
        ffmpeg_cmd.extend(["-t", str(duration)])
    ffmpeg_cmd.append(tmp_path)

    if duration:
        status_line = f"Recording {duration}s..."
    else:
        status_line = "Recording... (Ctrl+C to stop)"

    print(status_line, file=sys.stderr, end="", flush=True)

    proc = None
    try:
        proc = subprocess.Popen(
            ffmpeg_cmd,
            stderr=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
        )
        proc.wait()
    except KeyboardInterrupt:
        if proc is not None:
            proc.terminate()
            proc.wait()

    print(" done.", file=sys.stderr)
    print(f"Transcribing...", file=sys.stderr, end="", flush=True)

    text = whisper_transcribe(
        Path(tmp_path),
        model=args.model,
        language=args.language,
        json_out=args.json,
        progress=args.progress,
    )

    print(" done.", file=sys.stderr)

    if args.json:
        print(text)
    else:
        print(text)

    # Save to output file if specified
    if args.output:
        with open(args.output, "w") as f:
            f.write(text)
        print(f"Saved to {args.output}", file=sys.stderr)

    os.unlink(tmp_path)


def cmd_file(args):
    """Transcribe an existing audio file."""
    audio = Path(args.input)
    if not audio.exists():
        die(f"File not found: {args.input}")

    print(f"Transcribing {audio.name}...", file=sys.stderr, end="", flush=True)

    text = whisper_transcribe(
        audio,
        model=args.model,
        language=args.language,
        json_out=args.json,
        progress=args.progress,
    )

    print(" done.", file=sys.stderr)

    if args.json:
        print(text)
    else:
        print(text)

    if args.output:
        with open(args.output, "w") as f:
            f.write(text)


def _audio_rms(pcm_s16le: Union[bytes, bytearray]) -> float:
    """Root mean square energy of 16-bit PCM audio (0.0 = silence)."""
    if len(pcm_s16le) < 2:
        return 0.0
    import struct
    buf = memoryview(pcm_s16le)
    count = len(buf) // 2
    samples = struct.unpack(f"<{count}h", buf[: count * 2])
    return (sum(s * s for s in samples) / count) ** 0.5 / 32768.0


def _has_speech(pcm_s16le: Union[bytes, bytearray], threshold: float = 0.01, min_frames: int = 5) -> bool:
    """True if enough 0.1s frames exceed threshold (requires sustained speech)."""
    if len(pcm_s16le) < 3200:
        return _audio_rms(pcm_s16le) > threshold
    frame_len = 1600  # 0.1s at 16kHz mono s16le
    above = 0
    for i in range(0, len(pcm_s16le) - frame_len, frame_len // 2):
        if _audio_rms(pcm_s16le[i:i + frame_len]) > threshold:
            above += 1
            if above >= min_frames:
                return True
        else:
            above = 0  # reset on silent frame (requires consecutive)
    return False



# Hallucination garbage patterns that whisper emits for silence/noise
_HALLUCINATION_SUBSTRINGS = [
    "(crickets", "(scissors", "(keyboard", "(typing", "(phone",
    "(silence", "(wind", "(footsteps", "(music", "(breathing",
    "(applause", "(laughter", "(sigh", "(cough", "(sneeze",
    "[BLANK_AUDIO]", "[ Silence ]", "[Subscribe]",
    # Chinese YouTube / subtitle artifacts
    "字幕", "製作", "字幕製作", "熱點預測",
    "订阅", "訂閱", "点赞", "点讚", "分享",
    "关注", "關注", "一键三连", "弹幕",
    "字幕由", "自动生成", "自动生成字幕",
]

# Match any parenthetical segment: (...), [...], （...）, 【...】
_PAREN_RE = re.compile(r'[\(\[（【][^\)\]）】]*[\)\]）】]')


def _is_hallucination(text: str) -> bool:
    """Heuristic: detect whisper hallucination from silence/noise."""
    t = text.strip().lower()
    if not t:
        return True
    # Entire text is a parenthetical sound-effect description
    if t.startswith("(") and t.endswith(")"):
        return True
    if t.startswith("[") and t.endswith("]"):
        return True
    # Scan parenthetical segments anywhere in the text (handles
    # "(字幕製作:貝爾)" embedded inside normal speech)
    for match in _PAREN_RE.finditer(t):
        seg = match.group()
        for marker in _HALLUCINATION_SUBSTRINGS:
            if marker.lower() in seg:
                return True
    for marker in _HALLUCINATION_SUBSTRINGS:
        if marker.lower() in t:
            return True
    # Garbage: contains replacement characters or unusual Unicode blocks
    if "�" in t:
        return True
    # Count suspicious characters (non-Latin/CJK scripts that whisper
    # hallucinates from noise)
    suspicious = 0
    for ch in t:
        cp = ord(ch)
        if cp < 0x0020:
            continue
        if 0x0020 <= cp <= 0x024F:  # Latin + IPA
            continue
        if 0x3000 <= cp <= 0x9FFF:  # CJK
            continue
        if 0xFF00 <= cp <= 0xFFEF:  # Fullwidth forms
            continue
        if 0x2000 <= cp <= 0x206F:  # General punctuation
            continue
        if cp in (0x3000,):  # IDEOGRAPHIC SPACE is OK alone
            continue
        suspicious += 1
    if suspicious >= 3 and len(t) < 20:
        return True
    return False


def _build_wav(pcm_data: Union[bytes, bytearray], sample_rate: int = 16000) -> bytes:
    """Wrap raw PCM s16le data in a WAV container (in memory)."""
    import struct
    data_len = len(pcm_data)
    header = struct.pack(
        "<4sI4s4sIHHIIHH4sI",
        b"RIFF",
        36 + data_len,
        b"WAVE",
        b"fmt ",
        16,          # chunk size
        1,           # PCM
        1,           # mono
        sample_rate,
        sample_rate * 2,  # byte rate
        2,           # block align
        16,          # bits per sample
        b"data",
        data_len,
    )
    return header + bytes(pcm_data)


def cmd_stream(args):
    """Real-time streaming via whisper-server with sliding window."""
    INTERVAL = args.interval      # how often to send (seconds)
    model_path = resolve_model(args.model)
    device = getattr(args, "device", ":0")

    # 1. Start whisper-server (model loaded once, stays resident)
    port = _find_free_port()
    print(f"Starting whisper-server (port {port})...", file=sys.stderr, end="", flush=True)
    server_proc = _start_whisper_server(model_path, args.language, port)
    print(" ready.", file=sys.stderr)

    # 2. Start ffmpeg outputting raw PCM to stdout
    ffmpeg_proc = subprocess.Popen(
        [
            "ffmpeg", "-nostdin",
            "-f", "avfoundation", "-i", device,
            "-ar", "16000", "-ac", "1", "-f", "s16le",
            "-",
        ],
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        stdin=subprocess.DEVNULL,
    )

    # Accumulating buffer: all audio since stream start.
    bytes_per_sec = 16000 * 2  # 16kHz * 16-bit mono
    ring = bytearray()         # full accumulated audio
    last_text = ""
    silence_streak = 0
    ever_printed = False       # track first output for newline
    interrupted = False
    chunk_num = 0              # for per-chunk filenames

    # Energy gate: only check recent audio so silence isn't masked by
    # earlier speech. Hangover keeps sending briefly after speech ends
    # to capture trailing words.
    SPEECH_WINDOW = 1.5        # seconds of recent audio to scan
    HANGOVER_INTERVALS = 3     # keep sending N intervals after speech ends

    def on_interrupt(signum, frame):
        nonlocal interrupted
        interrupted = True

    prev_sigint = signal.signal(signal.SIGINT, on_interrupt)
    prev_sigterm = signal.signal(signal.SIGTERM, on_interrupt)

    print(f"Streaming (window={args.chunk}s, interval={INTERVAL}s, Ctrl+C to stop)...\n",
          file=sys.stderr)

    last_send = 0.0

    try:
        while not interrupted and ffmpeg_proc.poll() is None:
            # Non-blocking read from ffmpeg stdout
            ready, _, _ = select.select([ffmpeg_proc.stdout], [], [], 0.1)
            if ready:
                chunk = ffmpeg_proc.stdout.read(bytes_per_sec // 4)
                if chunk:
                    ring.extend(chunk)
                    # Cap at 60s to bound memory (60 * 32000 = ~1.9MB)
                    if len(ring) > 60 * bytes_per_sec:
                        ring = ring[-(30 * bytes_per_sec):]

            now = time.time()
            if now - last_send >= INTERVAL and len(ring) >= bytes_per_sec // 2:
                last_send = now

                # Energy gate: check only RECENT audio (not full buffer).
                # Once speech stops, the recent window goes silent even though
                # earlier parts of the buffer still have speech energy.
                recent_len = min(len(ring), int(bytes_per_sec * SPEECH_WINDOW))
                recent = ring[-recent_len:]
                rms = _audio_rms(recent)
                has_speech = _has_speech(recent, threshold=args.silence)

                if has_speech:
                    silence_streak = 0
                else:
                    silence_streak += 1
                    # Hangover: keep sending briefly after speech ends to
                    # capture trailing words, then stop to avoid hallucinations.
                    if silence_streak > HANGOVER_INTERVALS:
                        if args.verbose:
                            print(f"  [{len(ring)//bytes_per_sec:.1f}s] rms={rms:.4f} (silent)",
                                  file=sys.stderr, flush=True)
                        continue

                # Build WAV in memory and POST directly (no temp file)
                wav = _build_wav(ring)
                chunk_num += 1
                text = _transcribe_via_server(wav, f"chunk_{chunk_num}.wav", port, args.language)

                if args.verbose:
                    print(f"  [{len(ring)//bytes_per_sec:.1f}s, rms={rms:.4f}] → {text!r}",
                          file=sys.stderr, flush=True)

                # Filter hallucinations and duplicates
                if text and not _is_hallucination(text) and text != last_text:
                    if args.json:
                        print(json.dumps({
                            "chunk": chunk_num,
                            "time": round(len(ring) / bytes_per_sec, 1),
                            "text": text,
                        }), flush=True)
                    else:
                        was_silent = silence_streak > 4
                        ending = "\n" if was_silent or not ever_printed else ""
                        print(f"\r\033[K{text}", end=ending, flush=True)
                    last_text = text
                    silence_streak = 0
                    ever_printed = True

    except KeyboardInterrupt:
        pass
    finally:
        signal.signal(signal.SIGINT, prev_sigint)
        signal.signal(signal.SIGTERM, prev_sigterm)
        ffmpeg_proc.terminate()
        ffmpeg_proc.wait()
        server_proc.terminate()
        server_proc.wait()
        if ever_printed:
            if not args.json:
                print()  # final newline so shell prompt doesn't overwrite
        print("Stopped.", file=sys.stderr)


# ── Main ────────────────────────────────────────────────────────────

def main():
    check_deps()

    parser = argparse.ArgumentParser(
        prog="stt",
        description="Local speech-to-text using whisper.cpp on macOS",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = parser.add_subparsers(dest="command")

    # ── record ──
    p = sub.add_parser("record", help="Record from mic and transcribe")
    p.add_argument("-d", "--duration", type=int, default=None,
                   help="Recording duration in seconds (unlimited if omitted)")
    p.add_argument("-D", "--device", default=":0",
                   help="Audio input device (default: :0, use list-devices to find)")
    p.add_argument("-o", "--output", default=None,
                   help="Save transcription to file")
    p.add_argument("-m", "--model", default=DEFAULT_MODEL,
                   help="Model filename or path")
    p.add_argument("-l", "--language", default="auto",
                   help="Language code (auto/zh/en/ja/...)")
    p.add_argument("--json", action="store_true",
                   help="Output JSON with timestamps and confidence")
    p.add_argument("-p", "--progress", action="store_true",
                   help="Show whisper progress bar")
    p.set_defaults(func=cmd_record)

    # ── file ──
    p = sub.add_parser("file", help="Transcribe existing audio file")
    p.add_argument("input", help="Audio file path (wav/mp3/flac/ogg)")
    p.add_argument("-o", "--output", default=None,
                   help="Save transcription to file")
    p.add_argument("-m", "--model", default=DEFAULT_MODEL,
                   help="Model filename or path")
    p.add_argument("-l", "--language", default="auto",
                   help="Language code (auto/zh/en/ja/...)")
    p.add_argument("--json", action="store_true",
                   help="Output JSON with timestamps and confidence")
    p.add_argument("-p", "--progress", action="store_true",
                   help="Show whisper progress bar")
    p.set_defaults(func=cmd_file)

    # ── stream ──
    p = sub.add_parser("stream", help="Real-time streaming transcription")
    p.add_argument("-m", "--model", default=DEFAULT_MODEL,
                   help="Model filename or path")
    p.add_argument("-l", "--language", default="auto",
                   help="Language code (auto/zh/en/ja/...)")
    p.add_argument("-D", "--device", default=":0",
                   help="Audio input device (default: :0, use list-devices to find)")
    p.add_argument("-c", "--chunk", type=float, default=3.0,
                   help="Sliding window size in seconds (default: 3.0, more = better accuracy)")
    p.add_argument("-i", "--interval", type=float, default=0.5,
                   help="Send interval in seconds (default: 0.5, lower = faster)")
    p.add_argument("-s", "--silence", type=float, default=0.01,
                   help="RMS energy threshold per 0.1s frame (default: 0.01, lower = more sensitive)")
    p.add_argument("--json", action="store_true",
                   help="Output JSON lines (chunk number, time, text per line)")
    p.add_argument("-v", "--verbose", action="store_true",
                   help="Show RMS energy and server responses for debugging")
    p.set_defaults(func=cmd_stream)

    # ── list-devices ──
    p = sub.add_parser("list-devices", help="List audio input devices")
    p.set_defaults(func=lambda _: list_devices())

    args = parser.parse_args()

    if args.command is None:
        parser.print_help()
        sys.exit(0)

    args.func(args)


if __name__ == "__main__":
    main()
